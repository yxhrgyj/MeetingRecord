{
  "name": "meeting-assistant",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "node --test && vitest run",
    "test:server": "node --test",
    "test:ui": "vitest run tests/ui",
    "test:e2e": "playwright test",
    "d1:seed": "node scripts/generate-d1-seed.mjs",
    "deploy": "npm run build && wrangler pages deploy dist --project-name meeting-assistant",
    "start": "node server.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "@lucide/vue": "^1.24.0",
    "cors": "^2.8.5",
    "docx": "^9.7.1",
    "express": "^4.18.2",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.17",
    "jsdom": "^26.0.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "vite": "^5.0.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0"
  }
}
